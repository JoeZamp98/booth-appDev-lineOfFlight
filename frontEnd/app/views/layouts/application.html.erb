<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
      <%= content_for?(:title) ? yield(:title) + " · " : "" %>Line of Flight
    </title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
    <%= vite_javascript_tag "application.jsx" %>
    <!--
      If using a TypeScript entrypoint file:
        vite_typescript_tag 'application'

      If using a .jsx or .tsx entrypoint, add the extension:
        vite_javascript_tag 'application.jsx'

      Visit the guide for more information: https://vite-ruby.netlify.app/guide/rails
    -->

  </head>

  <body class="bg-[#F5F2ED] text-[#1a1a1a] min-h-screen antialiased">

    <%# ── Top nav ── %>
    <header class="border-b border-[#E0DCD5] bg-[#F5F2ED]/95 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-14 flex items-center gap-8">

        <%# Logo %>
        <a href="/" class="flex items-center gap-2.5 shrink-0">
          <svg width="26" height="26" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="13" stroke="#1a1a1a" stroke-width="1.5"/>
            <path d="M7 17 L14 8 L21 17" stroke="#1a1a1a" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <path d="M10 17 L18 17" stroke="#1a1a1a" stroke-width="1" stroke-linecap="round"/>
          </svg>
          <span class="text-sm font-semibold tracking-widest uppercase">Line of Flight</span>
        </a>

        <%# Nav links %>
        <nav class="flex items-center gap-1 ml-2">
          <%= nav_link "Predict", new_prediction_path %>
          <%= nav_link "Trips",   trips_path %>
          <%= nav_link "Flights", flights_path %>
        </nav>

        <%# User menu %>
        <% if current_user %>
          <% user_initials = current_user.initials.presence ||
                             current_user.name.to_s.split.map(&:first).first(2).join %>
          <details class="ml-auto relative group [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex items-center gap-3 cursor-pointer list-none select-none">
              <span class="text-right leading-tight hidden sm:block">
                <span class="block text-sm font-medium"><%= current_user.name %></span>
                <% if current_user.tier.present? %>
                  <span class="block text-xs text-[#888]"><%= current_user.tier %></span>
                <% end %>
              </span>
              <div class="w-8 h-8 rounded-full bg-[#1a1a1a] text-white text-xs font-semibold
                          flex items-center justify-center ring-2 ring-transparent
                          group-open:ring-[#1a1a1a]/15 transition-all">
                <%= user_initials %>
              </div>
            </summary>

            <div class="absolute right-0 mt-2 w-60 bg-white border border-[#E0DCD5]
                        rounded-xl shadow-lg overflow-hidden z-50">
              <div class="px-4 py-3 border-b border-[#F0ECE8]">
                <p class="text-sm font-semibold"><%= current_user.name %></p>
                <p class="text-xs text-[#888] mt-0.5">@<%= current_user.username %></p>
                <div class="flex flex-wrap items-center text-align-center gap-1.5 mt-2">
                  <% if current_user.tier.present? %>
                    <span class="text-[10px] font-medium
                                 px-4 py-4 rounded-full bg-[#1a1a1a] text-white">
                      <%= current_user.tier %>
                    </span>
                  <% end %>
                </div>
              </div>
              <%= button_to logout_path, method: :delete,
                    class: "w-full flex items-center gap-2 px-4 py-4 text-sm font-medium
                            text-[#c0392b] hover:bg-[#FAF5F4] transition-colors cursor-pointer" do %>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="shrink-0">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"
                        stroke="currentColor" stroke-width="1.8"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <div class="text-align-center my-6">
                  Sign out
                </div>
              <% end %>
            </div>
          </details>
        <% end %>

      </div>
    </header>

    <%# ── Breadcrumb ── %>
    <% if content_for?(:breadcrumb) %>
      <div class="border-b border-[#E0DCD5]">
        <div class="max-w-7xl mx-auto px-6 h-10 flex items-center justify-between
                    text-xs text-[#888]">
          <div><%= yield :breadcrumb %></div>
          <div class="tabular-nums">updated · <%= Time.now.strftime("%H:%M:%S") %> PDT</div>
        </div>
      </div>
    <% end %>

    <%# ── Page content ── %>
    <main class="max-w-7xl mx-auto px-6 py-8">
      <%= yield %>
    </main>

    <%# Close the user menu when clicking outside or pressing Escape %>
    <script>
      document.addEventListener("click", function (e) {
        document.querySelectorAll("details[open]").forEach(function (d) {
          if (!d.contains(e.target)) d.removeAttribute("open");
        });
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          document.querySelectorAll("details[open]").forEach(function (d) {
            d.removeAttribute("open");
          });
        }
      });
    </script>

  </body>
</html>