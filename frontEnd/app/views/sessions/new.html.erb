<% content_for :title, "Sign in" %>

<div class="w-full max-w-sm">

    <%# Logo %>
    <div class="flex items-center justify-center gap-2.5 mb-8">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="14" r="13" stroke="#1a1a1a" stroke-width="1.5"/>
        <path d="M7 17 L14 8 L21 17" stroke="#1a1a1a" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <path d="M10 17 L18 17" stroke="#1a1a1a" stroke-width="1"
              stroke-linecap="round"/>
      </svg>
      <span class="text-sm font-semibold tracking-widest uppercase">
        Line of Flight
      </span>
    </div>
  
    <div class="bg-white rounded-xl border border-[#E0DCD5] p-8">
      <h1 class="text-2xl font-light mb-1">Sign in</h1>
      <p class="text-sm text-[#888] mb-6">Welcome back.</p>
  
      <% if @error %>
        <div class="bg-[#fcecea] border border-[#e8b4b0] text-[#8b1a14]
                    text-sm rounded-lg px-4 py-3 mb-4">
          <%= @error %>
        </div>
      <% end %>
  
      <%= form_with url: login_path, method: :post,
            data: { turbo: false }, class: "flex flex-col gap-4" do |f| %>
  
        <div>
          <label class="text-xs font-semibold tracking-widest text-[#aaa]
                         uppercase mb-1 block">Username</label>
          <%= f.text_field :username,
                autocomplete: "username",
                class: "w-full border border-[#E0DCD5] rounded-lg px-4 py-3
                        text-sm focus:outline-none focus:border-[#1a1a1a]
                        transition-colors bg-white" %>
        </div>
  
        <div>
          <label class="text-xs font-semibold tracking-widest text-[#aaa]
                         uppercase mb-1 block">Password</label>
          <%= f.password_field :password,
                autocomplete: "current-password",
                class: "w-full border border-[#E0DCD5] rounded-lg px-4 py-3
                        text-sm focus:outline-none focus:border-[#1a1a1a]
                        transition-colors bg-white" %>
        </div>
  
        <%= f.submit "Sign in",
              class: "w-full bg-[#1a1a1a] text-white text-sm font-medium
                      py-3 rounded-lg hover:bg-[#333] transition-colors
                      cursor-pointer mt-1" %>
  
      <% end %>
  
      <p class="text-xs text-[#aaa] text-center mt-5 leading-relaxed">
        daniel / fly123 &nbsp;·&nbsp;
        sarah / fly123 &nbsp;·&nbsp;
        marcus / fly123
      </p>
    </div>
  
  </div>